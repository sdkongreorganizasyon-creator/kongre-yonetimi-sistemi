# Bu dosya yalnızca örnektir.
# Gerçek anahtarları GitHub'a veya proje dosyalarına kesinlikle eklemeyin.
# Değerleri Streamlit Cloud > App > Settings > Secrets alanına girin.

FIREBASE_ENABLED = true

# Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON = '''
{
  "type": "service_account",
  "project_id": "BURAYA_PROJECT_ID",
  "private_key_id": "BURAYA_PRIVATE_KEY_ID",
  "private_key": "-----BEGIN PRIVATE KEY-----\nBURAYA_PRIVATE_KEY\n-----END PRIVATE KEY-----\n",
  "client_email": "BURAYA_SERVICE_ACCOUNT_EPOSTASI",
  "client_id": "BURAYA_CLIENT_ID",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "BURAYA_CLIENT_CERT_URL",
  "universe_domain": "googleapis.com"
}
'''

# Firebase Console > Project settings > General > Your apps > Web app > SDK setup and configuration
# Buradaki web ayarları gizli anahtar değildir; yine de tek noktadan yönetmek için Secrets içinde tutulur.
FIREBASE_WEB_CONFIG = '''
{
  "apiKey": "BURAYA_WEB_API_KEY",
  "authDomain": "BURAYA_PROJECT_ID.firebaseapp.com",
  "projectId": "BURAYA_PROJECT_ID",
  "storageBucket": "BURAYA_STORAGE_BUCKET",
  "messagingSenderId": "BURAYA_MESSAGING_SENDER_ID",
  "appId": "BURAYA_APP_ID"
}
'''

# Mevcut yapay zeka ayarlarınız varsa Streamlit Secrets alanında koruyun.
GEMINI_API_KEY = "BURAYA_GEMINI_API_KEY"
GEMINI_MODEL = "gemini-2.5-flash-lite"
