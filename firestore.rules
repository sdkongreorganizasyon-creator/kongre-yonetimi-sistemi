rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function appUserId() {
      return request.auth.token.appUserId;
    }

    function validModule(moduleName) {
      return moduleName in [
        "organizations", "crm", "offers", "tenders", "contracts",
        "budgets", "officeExpenses", "invoices", "suppliers",
        "equipment", "travel", "risks", "documents", "checklists",
        "postEvents", "communications", "notifications", "logs", "settings"
      ];
    }

    // Ortak iş yönetimi koleksiyonu:
    // Her Firebase oturumu açmış EVENTIX kullanıcısı tüm kayıtları görebilir.
    // Kayıt yalnızca sahibi veya Süper Admin tarafından değiştirilebilir.
    match /system_shared_records/{documentId} {
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerId is string
        && request.resource.data.module is string
        && request.resource.data.recordId is string
        && request.resource.data.payload is map
        && validModule(request.resource.data.module)
        && request.resource.data.payload.ownerId == request.resource.data.ownerId
        && request.resource.data.payload.id == request.resource.data.recordId
        && (isSuperAdmin() || request.resource.data.ownerId == appUserId())
        && (request.resource.data.module != "settings" || isSuperAdmin());

      allow update: if signedIn()
        && (isSuperAdmin() || resource.data.ownerId == appUserId())
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.module == resource.data.module
        && request.resource.data.recordId == resource.data.recordId
        && request.resource.data.payload is map
        && request.resource.data.payload.ownerId == resource.data.ownerId
        && request.resource.data.payload.id == resource.data.recordId
        && validModule(request.resource.data.module)
        && (request.resource.data.module != "settings" || isSuperAdmin())
        && (request.resource.data.module != "logs" || isSuperAdmin());

      // Uygulama fiziksel silme yapmaz; isDeleted alanını güncelleyerek güvenli siler.
      allow delete: if false;
    }

    // Kullanıcı listesi yalnızca Streamlit sunucusundaki Firebase Admin SDK ile yönetilir.
    match /system_private/{document=**} {
      allow read, write: if false;
    }

    // Ekonomi paneli istemciler tarafından okunabilir, değiştirilemez.
    match /system_public/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
